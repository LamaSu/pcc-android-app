# Copy to .env.local for local dev. .env.local is gitignored.

# Where the Android shell polls for updates.
VITE_OTA_MANIFEST_URL=https://capability.network/android-ota/manifest.json

# Public Ed25519 (or RSA) key used to verify OTA bundle signatures.
# Generate via: openssl pkey -in secrets/private-signing-key.pem -pubout
# Paste the PEM body (without BEGIN/END lines) here.
VITE_OTA_PUBLIC_KEY=

# Where the dashboard lives (used by the placeholder splash screen).
VITE_GATEWAY_URL=https://capability.network

# PCC gateway base URL used by src/lib/api.ts.
# Defaults to https://capability.network when unset.
VITE_PCC_GATEWAY_URL=https://capability.network

# Dev-only PCC API key. The shell preferentially reads
# localStorage.PCC_API_KEY (set via the Settings screen at runtime); this
# env var is only used when localStorage is empty (e.g., first launch).
# NEVER bake a production key into the binary — leave this blank for
# release builds and set the key from the Settings screen.
VITE_PCC_API_KEY=
